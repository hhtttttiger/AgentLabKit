# Database
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_USER=app
APP_DB_PASSWORD=change-me
APP_DB_NAME=agentlabkit

# AI Gateway (LLM catalog — uses the same PostgreSQL as the main app)
APP_GATEWAY__CATALOG_DATABASE_URL=postgresql+asyncpg://app:change-me@localhost:5432/agentlabkit
APP_GATEWAY__CATALOG_ENCRYPT_KEY=change-me-encrypt-key

# JWT
APP_JWT_SECRET_KEY=change-me-in-production
APP_JWT_ISSUER=agentlabkit
APP_JWT_AUDIENCE=agentlabkit
APP_JWT_EXPIRES_MINUTES=480

# File storage
APP_FILE_STORAGE_LOCAL_BASE_PATH=./uploads

# Debug
APP_DEBUG=false

# Redis
APP_REDIS_URL=redis://localhost:6379/0
APP_REDIS_ENABLED=false

# Retrieval (RAG)
APP_RETRIEVAL_ENABLED=false
APP_EMBEDDING_MODEL=text-embedding-3-small
APP_EMBEDDING_DIMENSIONS=1536
APP_RETRIEVAL_TOP_K=5
# Hybrid search (RRF fusion constant; higher = less weight on rank)
APP_RETRIEVAL__RRF_K=60
# pg_trgm similarity threshold (0.0-1.0)
APP_RETRIEVAL__TRGM_SIMILARITY_THRESHOLD=0.1
# HNSW index params (set at index creation time)
APP_RETRIEVAL__HNSW_M=16
APP_RETRIEVAL__HNSW_EF_CONSTRUCTION=64

# Long-Term Memory
LONG_TERM_MEMORY_ENABLED=false
LONG_TERM_MEMORY_EXTRACTION_MODEL=change-me

# Observability (tracing)
# OBSERVABILITY_ENABLED=true
# OBSERVABILITY_MAX_SPANS_PER_TRACE=500
